# =============================================================
#  Configurações do MCP Server
# =============================================================

# Server security
API_KEY=supersecretkey
RATE_LIMIT_PER_IP=10
RATE_LIMIT_GLOBAL=50
RATE_LIMIT_WINDOW=60
REQUEST_TIMEOUT=180

# Ollama
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_URL=http://ollama:11434
INPUT_MAX_LENGTH=1000

# Servidor
SERVER_ADDR=:8081

# =============================================================
#  Navegação do Host (gerenciado automaticamente pelo cli.sh
#  ou cli.ps1 — não precisa editar manualmente)
# =============================================================

# Linux/Mac: HOST_ROOT=/
# Windows WSL2: HOST_ROOT=/mnt/c
# Windows Docker Desktop: HOST_ROOT=C:\
HOST_ROOT=/

# Diretório atual do host no momento que o CLI foi aberto
# Preenchido automaticamente pelo wrapper cli.sh / cli.ps1
HOST_CWD=/

# Logs
LOG_DIR=/app/logs

# Business logic
CONFIDENCE_THRESHOLD=0.8